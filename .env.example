# ─── Base de datos (Supabase PostgreSQL) ───────────────────
# Puerto 6543 con pgbouncer → para la app en Vercel (serverless)
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"
# Puerto 5432 directo → solo para migraciones de Prisma
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# ─── Supabase Realtime ──────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT-REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY=""

# ─── Auth.js v5 ─────────────────────────────────────────────
# Genera uno con: openssl rand -base64 32
AUTH_SECRET=""
# Google OAuth (console.cloud.google.com → Credenciales → OAuth 2.0)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# ─── Resend (emails transaccionales) ───────────────────────
RESEND_API_KEY="re_..."
EMAIL_FROM="Danu <noreply@resend.dev>"

# ─── Vercel Cron Jobs (pon cualquier string secreto tú mismo) ─
CRON_SECRET="pon-aqui-cualquier-frase-secreta-larga"

# ─── App ────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
