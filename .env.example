# ─── Base de datos (Supabase PostgreSQL) ───────────────────
# Puerto 6543 con pgbouncer → para la app en Vercel (serverless)
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
# Puerto 5432 directo → solo para prisma db push
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# ─── Supabase Realtime ──────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT-REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY=""

# ─── Auth.js v5 (GitHub OAuth) ──────────────────────────────
# Genera AUTH_SECRET con: openssl rand -base64 32
AUTH_SECRET=""
# GitHub → Settings → Developer settings → OAuth Apps
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# ─── Vercel Cron Jobs ───────────────────────────────────────
CRON_SECRET="pon-aqui-cualquier-frase-secreta-larga"

# ─── App ────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
